<Page x:Class="Carbon.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Carbon"
      mc:Ignorable="d"
      Title="Settings">
    <Grid>
        <TextBox>Welcome to settings</TextBox>
        <StackPanel>
            <Button Content="Authenticate" Width="100" Height="30" Click="Authenticate" Margin="20"/>
            <Button Content="Print Token" Width="100" Height="30" Click="PrintToken" Margin="20"/>
            <Button Content="Switch API" Width="100" Height="30" Click="SwitchAPI" Margin="20"/>
        </StackPanel>
    </Grid>
</Page>
